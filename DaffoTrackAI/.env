# Database Config
MYSQL_DATABASE=railway
MYSQL_ROOT_PASSWORD=YLLmQQxpzAXpZwznZaFQnjotEjbXNsLa
DATABASE_USERNAME=root
DATABASE_PASSWORD=${MYSQL_ROOT_PASSWORD}

# Railway Private/Public Domain (তুমি Railway Dashboard থেকে আসল ডোমেইন বসাবে)
MYSQLHOST=containers-us-west-123.railway.app
MYSQLPORT=3306

# JDBC URLs
DATABASE_URL=jdbc:mysql://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@${MYSQLHOST}:${MYSQLPORT}/${MYSQL_DATABASE}?useSSL=false&serverTimezone=UTC
MYSQL_PUBLIC_URL=jdbc:mysql://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@${MYSQLHOST}:${MYSQLPORT}/${MYSQL_DATABASE}?useSSL=false&serverTimezone=UTC

# Driver
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
